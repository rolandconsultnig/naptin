# Copy to repository root as `.env` (e.g. /opt/naptin/.env if you cloned there) and chmod 600
# 4001 = vite preview (SPA) | 4002 = Node API | 4003 = Owl Talk

DATABASE_URL=postgresql://naptin_app:CHANGE_ME@127.0.0.1:5432/naptin_portal
API_PORT=4002
ACCESS_GOVERNANCE_WEBHOOK_URL=
ACCESS_GOVERNANCE_WEBHOOK_SECRET=
ACCESS_AUDIT_HASH_SECRET=
ACCESS_GOVERNANCE_EMAIL_WEBHOOK_URL=
ACCESS_GOVERNANCE_EMAIL_API_KEY=
ACCESS_GOVERNANCE_ALERT_EMAILS=superadmin@naptin.gov.ng
ACCESS_GOVERNANCE_AUTOMATION_ENABLED=true
ACCESS_GOVERNANCE_AUTOMATION_INTERVAL_MS=300000
ACCESS_GOVERNANCE_AUTOMATION_ACTOR=system@naptin.gov.ng
ACCESS_DASHBOARD_CACHE_TTL_MS=60000
ACCESS_RISK_INCREMENTAL_BATCH_SIZE=2000
ACCESS_QUERY_PERF_LOG_THRESHOLD_MS=250
ACCESS_QUERY_PERF_THRESHOLD_REFRESH_MS=60000
ACCESS_QUERY_PERF_AUTO_TUNE_INTERVAL_MS=900000
ACCESS_QUERY_PERF_DRIFT_ALERT_RATIO=1.25
ACCESS_QUERY_PERF_INCIDENT_EVAL_INTERVAL_MS=120000
ACCESS_QUERY_PERF_INCIDENT_MIN_SAMPLES=8
ACCESS_QUERY_PERF_INCIDENT_DRIFT_RATIO=1.35
ACCESS_QUERY_PERF_INCIDENT_SPIKE_RATIO=1.7
ACCESS_QUERY_PERF_INCIDENT_NEW_SLOW_P95_MS=600
ACCESS_QUERY_PERF_INCIDENT_SLOW_HIT_COUNT=3
ACCESS_QUERY_PERF_INCIDENT_CRITICAL_SLA_MINUTES=30
ACCESS_QUERY_PERF_INCIDENT_WARNING_SLA_MINUTES=240
ACCESS_QUERY_PERF_INCIDENT_SLA_SUSTAINED_DRIFT_MINUTES=60
ACCESS_QUERY_PERF_INCIDENT_SLA_SPIKE_PERSISTENCE_MINUTES=30
ACCESS_QUERY_PERF_INCIDENT_SLA_NEWLY_SLOW_QUERY_MINUTES=120
ACCESS_QUERY_PERF_INCIDENT_ESCALATION_COOLDOWN_MINUTES=30
ACCESS_QUERY_PERF_INCIDENT_ESCALATION_MAX_LEVEL=3
ACCESS_QUERY_PERF_INCIDENT_ESCALATION_INTERVAL_MS=120000
ACCESS_QUERY_PERF_INCIDENT_ESCALATION_EMAILS=superadmin@naptin.gov.ng
ACCESS_QUERY_PERF_ESCALATION_L1_EMAILS=superadmin@naptin.gov.ng
ACCESS_QUERY_PERF_ESCALATION_L2_EMAILS=
ACCESS_QUERY_PERF_ESCALATION_L3_EMAILS=
ACCESS_QUERY_PERF_ESCALATION_CRITICAL_L1_EMAILS=
ACCESS_QUERY_PERF_ESCALATION_CRITICAL_L2_EMAILS=
ACCESS_QUERY_PERF_ESCALATION_CRITICAL_L3_EMAILS=
ACCESS_QUERY_PERF_INCIDENT_ESCALATION_LEVEL_COOLDOWNS=30,60,120
ACCESS_QUERY_PERF_INCIDENT_NOTIFICATION_SUPPRESSION_MINUTES=20
ACCESS_QUERY_PERF_LOG_RETENTION_DAYS=30
ACCESS_QUERY_PERF_INCIDENT_RETENTION_DAYS=180
ACCESS_QUERY_PERF_INCIDENT_EVENT_RETENTION_DAYS=365

# Browser must reach the API — use the server's public host/IP (never 127.0.0.1 in VITE_*: Chrome blocks public pages → loopback).
# Example UI at http://13.53.33.63:4001 → API on 4002:
# VITE_WORKBENCH_API_URL=http://13.53.33.63:4002/api/v1
# VITE_CHAT_API_URL=http://13.53.33.63:4003/api
# VITE_CHAT_SOCKET_URL=http://13.53.33.63:4003
VITE_WORKBENCH_API_URL=http://YOUR_PUBLIC_IP_OR_DOMAIN:4002/api/v1
VITE_CHAT_API_URL=http://YOUR_PUBLIC_IP_OR_DOMAIN:4003/api
VITE_CHAT_SOCKET_URL=http://YOUR_PUBLIC_IP_OR_DOMAIN:4003

# --- NAPTIN Chat (Owl Talk, Python on port 4003) — keep HTTP/HTTPS consistent ---
# Repo ships dev/ssl/*.pem. Without OWL_TALK_DISABLE_SSL=1, Owl binds HTTPS on 4003; your VITE_CHAT_* scheme and Nginx
# proxy_pass must use https://127.0.0.1:4003 (or terminate TLS only at Nginx and use HTTP to Owl — typical below).
# PM2 deploy/pm2.ecosystem.config.cjs defaults OWL_TALK_DISABLE_SSL=1 unless you override in this .env.
OWL_TALK_DISABLE_SSL=1
# POST /api/portal-sync: align Owl password with SPA naptin-* when user exists (same DB). Set 0/false on untrusted WAN.
OWL_PORTAL_SYNC=1
# Extra allowed browser origins (comma-separated, no spaces). Required e.g. for https://portal.example.com (no :4001).
# OWL_TALK_CORS_ORIGINS=https://portal.example.com
# Optional: Owl reads same DB as portal unless you split chat data.
# OWL_TALK_DATABASE_URL=postgresql://naptin_app:CHANGE_ME@127.0.0.1:5432/naptin_portal
# Local npm run dev only: Vite proxies /proxy-chat-* to 127.0.0.1:4003 — must match Owl (http default, https if certs + no disable).
# VITE_CHAT_BACKEND_PROTOCOL=http

# Capacitor Android/iOS: same variables must be present when you run `npm run build`
# (the native WebView does not infer your API host from the SPA URL).
#
# Internal APK (sideload, not Play Store): set VITE_* above, then from repo root:
#   npm run mobile:apk:debug    → android/app/build/outputs/apk/debug/app-debug.apk
#   npm run mobile:apk:release  → android/app/build/outputs/apk/release/app-release.apk
# Requires JDK, ANDROID_HOME (or android/local.properties sdk.dir=... from Android Studio).
# Release APK uses the debug keystore — fine for internal devices only, not for Play Store.
#
# Full native app (Expo / React Native) lives in /native — set native/.env with EXPO_PUBLIC_API_URL
# (same API base as VITE_WORKBENCH_API_URL). Run from repo root: npm run native:start
# Native release APK (Windows): npm run native:apk:release — see native/env.example for Gradle path note.

# Build on server after editing:
#   npm run build

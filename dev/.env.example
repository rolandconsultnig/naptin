# Owl Talk — optional overrides (dev/main.py loads repo-root `.env` first, then `dev/.env`).
# Copy to `dev/.env` and uncomment lines you need. Do not commit `dev/.env`.
# Production contract (HTTP/HTTPS, CORS, portal sync): see deploy/env.production.example → “NAPTIN Chat”.

# Use a different Postgres URL than root DATABASE_URL (optional)
# OWL_TALK_DATABASE_URL=postgresql://user:password@127.0.0.1:5432/naptin_db

# Extra CORS origins, comma-separated, no spaces (main.py already allows common dev ports)
# OWL_TALK_CORS_ORIGINS=https://your-domain.com

# OWL_TALK_PORT=4003
# FLASK_ENV=production
# Serve HTTP on 4003 even if dev/ssl/*.pem exist (recommended behind Nginx / matches http:// VITE_* URLs)
# OWL_TALK_DISABLE_SSL=1

# Allow POST /api/portal-sync — reset Owl password to SPA `naptin-*` secret when email exists (intranet/same-team only)
# OWL_PORTAL_SYNC=1

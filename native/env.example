# Copy to ".env" in this folder. Expo reads EXPO_PUBLIC_* at bundling time.
# Physical device: use your PC's LAN IP (not localhost). Emulator: default in src/config.ts uses 10.0.2.2.
EXPO_PUBLIC_API_URL=http://192.168.0.10:4002/api/v1

# Windows release APK: Gradle + prefab paths can exceed 260 chars. Use a short Gradle home, e.g.:
#   npm run apk:release
# (uses native/scripts/android-release.ps1, default GRADLE_USER_HOME=E:\g) or set GRADLE_USER_HOME yourself.

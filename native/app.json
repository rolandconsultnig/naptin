{
  "expo": {
    "name": "NAPTIN",
    "slug": "naptin-native",
    "scheme": "naptin",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#006838"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "ng.gov.naptin.portalnative"
    },
    "android": {
      "package": "ng.gov.naptin.portalnative",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#006838"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "./plugins/withAppAndroidMinSdk24",
      "./plugins/withAndroidLibraryMinSdk",
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 24
          }
        }
      ]
    ]
  }
}

DATABASE_URL=postgresql://naptin_user:Samolan@127.0.0.1:5432/naptin_db

# Node workbench API (server/index.js)
API_PORT=4002
# Browser → Node API (must not be the Vite UI port unless /api/v1 is proxied there)
VITE_WORKBENCH_API_URL=http://localhost:4002/api/v1

# Owl Talk (dev/main.py) — default port 4003; Vite dev proxies to 127.0.0.1:4003 (vite.config.js).
# Chat data lives in the same PostgreSQL database as the portal (DATABASE_URL → naptin_db) unless you set OWL_TALK_DATABASE_URL.
# Start from repo root: npm run chat   (or: python dev/main.py)
# VITE_CHAT_BACKEND_PROTOCOL=http
# VITE_CHAT_USE_VITE_PROXY=0
# VITE_CHAT_API_URL=http://127.0.0.1:4003/api
# VITE_CHAT_SOCKET_URL=http://127.0.0.1:4003
# Optional WebRTC ICE config (recommended for reliable calls across NAT/firewalls):
# VITE_CHAT_STUN_URLS=stun:stun.l.google.com:19302,stun:stun1.l.google.com:19302
# VITE_CHAT_TURN_URLS=turn:turn.your-domain.com:3478,turns:turn.your-domain.com:5349
# VITE_CHAT_TURN_USERNAME=naptin-turn-user
# VITE_CHAT_TURN_CREDENTIAL=replace-with-strong-secret

# Collaboration — optional links shown on the Office & WPS tab (no secrets; public URLs only)
# COLLAB_SHAREPOINT_HOME_URL=https://yourtenant.sharepoint.com/sites/YourSite
# COLLAB_WPS_HOME_URL=https://www.wps.com
# COLLAB_TEAMS_DEEP_LINK=https://teams.microsoft.com/l/team/...

# Production deploy guide + Nginx examples: deploy/README.md
